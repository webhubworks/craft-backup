<div class="cb-cards">
    {% if configError %}
        <div class="cb-card">
            <div class="cb-error">
                {{ 'Could not load backup configuration:'|t('backup') }}
                <code>{{ configError }}</code>
            </div>
        </div>
    {% else %}
        <div data-cb-card="health">
            <div class="cb-card cb-card--skeleton" aria-busy="true">
                <h2>{{ 'Backup health'|t('backup') }}</h2>
                <div class="cb-skeleton cb-skeleton--row"></div>
                <div class="cb-skeleton cb-skeleton--row"></div>
                <div class="cb-skeleton cb-skeleton--row cb-skeleton--short"></div>
            </div>
        </div>

        {% if monitorEnabled %}
            <div data-cb-card="checks">
                <div class="cb-card cb-card--skeleton" aria-busy="true">
                    <h2>{{ 'Per-target checks'|t('backup') }}</h2>
                    <div class="cb-skeleton cb-skeleton--row"></div>
                    <div class="cb-skeleton cb-skeleton--row"></div>
                </div>
            </div>
        {% endif %}

        <div data-cb-card="backups">
            <div class="cb-card cb-card--skeleton" aria-busy="true">
                <h2>{{ 'Backups by target'|t('backup') }}</h2>
                <div class="cb-skeleton cb-skeleton--row"></div>
                <div class="cb-skeleton cb-skeleton--row"></div>
                <div class="cb-skeleton cb-skeleton--row cb-skeleton--short"></div>
            </div>
        </div>
    {% endif %}
</div>
