{% from 'backup/_macros' import formatBytes, relativeTime %}

<div class="cb-card">
    <h2>{{ 'Backups by target'|t('backup') }}</h2>

    {% if backupsByTarget is empty %}
        <div class="cb-list__empty">{{ 'No targets configured.'|t('backup') }}</div>
    {% else %}
        {% set targetTabs = {} %}
        {% for targetName in backupsByTarget|keys %}
            {% set paneId = 'cb-target-' ~ loop.index %}
            {% set targetTabs = targetTabs|merge({
                (paneId): {
                    label: targetName,
                    url: '#' ~ paneId,
                },
            }) %}
        {% endfor %}

        <header class="pane-header cb-tabs-header">
            {% include '_includes/tabs.twig' with {
                tabs: targetTabs,
                containerAttributes: {
                    id: 'cb-target-tabs',
                },
            } only %}
        </header>

        <div class="cb-tab-panes">
            {% for targetName, target in backupsByTarget %}
                {% set paneId = 'cb-target-' ~ loop.index %}
                {% set isLocal = target.driver == 'local' %}
                {% set showDownload = isLocal and canDownload %}
                <div id="{{ paneId }}" class="cb-tab-pane{% if not loop.first %} hidden{% endif %}">
                    <div class="cb-list">
                        {% if target.backups|length %}
                            <table>
                                <thead>
                                    <tr>
                                        <th>{{ 'File'|t('backup') }}</th>
                                        <th>{{ 'Size'|t('backup') }}</th>
                                        <th>{{ 'Created'|t('backup') }}</th>
                                        {% if showDownload %}<th class="cb-col-action"></th>{% endif %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for backup in target.backups %}
                                        {% set tooLarge = showDownload and downloadMaxBytes is not null and backup.size > downloadMaxBytes %}
                                        <tr>
                                            <td class="cb-mono">
                                                {{ backup.name }}
                                                {% if backup.encrypted is same as(true) %}
                                                    <span class="cb-lock" title="{{ 'Password protected'|t('backup') }}" aria-label="{{ 'Password protected'|t('backup') }}">
                                                        <svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true" focusable="false">
                                                            <path fill="currentColor" d="M8 1a3.5 3.5 0 0 0-3.5 3.5V7H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1h-.5V4.5A3.5 3.5 0 0 0 8 1Zm-2 6V4.5a2 2 0 1 1 4 0V7H6Z"/>
                                                        </svg>
                                                    </span>
                                                {% elseif backup.encrypted is same as(false) %}
                                                    <span class="cb-lock cb-lock--open" title="{{ 'Not password protected'|t('backup') }}" aria-label="{{ 'Not password protected'|t('backup') }}">
                                                        <svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true" focusable="false">
                                                            <path fill="currentColor" d="M11.5 7V4.5a3.5 3.5 0 0 0-6.93-.66 .75.75 0 0 0 1.47.28 2 2 0 0 1 3.96.38V7H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1h-.5Z"/>
                                                        </svg>
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td>{{ formatBytes(backup.size) }}</td>
                                            <td>{{ relativeTime(backup.modified, dateTimeFormat) }}</td>
                                            {% if showDownload %}
                                                <td class="cb-col-action">
                                                    {% if tooLarge %}
                                                        <span class="cb-download cb-download--disabled cb-tooltip"
                                                              data-cb-tooltip="{{ 'Backup is {size}, exceeding the {limit} download limit. Fetch directly from the server: {path}'|t('backup', {
                                                                  size: formatBytes(backup.size),
                                                                  limit: formatBytes(downloadMaxBytes),
                                                                  path: backup.path,
                                                              }) }}"
                                                              aria-disabled="true">
                                                            {{ 'Too large'|t('backup') }}
                                                        </span>
                                                    {% else %}
                                                        <form method="post" accept-charset="UTF-8" class="cb-download-form">
                                                            {{ csrfInput() }}
                                                            {{ actionInput('backup/backup/download') }}
                                                            <input type="hidden" name="targetName" value="{{ targetName }}">
                                                            <input type="hidden" name="backupName" value="{{ backup.name }}">
                                                            <button type="submit" class="btn small cb-download" data-icon="download">{{ 'Download'|t('backup') }}</button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            {% endif %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <div class="cb-list__empty">{{ 'No backups found on this target.'|t('backup') }}</div>
                        {% endif %}
                    </div>

                    <div class="cb-legend">
                        {% if isLocal %}
                            <p>
                                <span class="cb-lock" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M8 1a3.5 3.5 0 0 0-3.5 3.5V7H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1h-.5V4.5A3.5 3.5 0 0 0 8 1Zm-2 6V4.5a2 2 0 1 1 4 0V7H6Z"/>
                                    </svg>
                                </span>
                                {{ 'File is password protected.'|t('backup') }}
                            </p>
                            <p>
                                <span class="cb-lock cb-lock--open" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M11.5 7V4.5a3.5 3.5 0 0 0-6.93-.66 .75.75 0 0 0 1.47.28 2 2 0 0 1 3.96.38V7H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1h-.5Z"/>
                                    </svg>
                                </span>
                                {{ 'File is not password protected.'|t('backup') }}
                            </p>
                        {% endif %}
                        <p class="cb-legend__note">{{ 'Zip detection is available for local targets only.'|t('backup') }}</p>
                    </div>

                    {% if target.diskUsage %}
                        {% set total = target.diskUsage.total %}
                        {% set free = target.diskUsage.free %}
                        {% set used = total - free %}
                        {% set backupsBytes = target.backupsBytes ?? 0 %}
                        {# Cap the backup-portion at the bar's used width so a stale total + fresh listing can't overflow visually. #}
                        {% set backupsBytesShown = backupsBytes > used ? used : backupsBytes %}
                        {% set thresholdInfo = target.warnThreshold %}
                        {% set threshold = thresholdInfo ? thresholdInfo.bytes : null %}
                        {% set thresholdPercent = thresholdInfo ? thresholdInfo.percent : null %}
                        {% set percentLabel = thresholdPercent is not null
                            ? (thresholdPercent == thresholdPercent|round(0)
                                ? thresholdPercent|number_format(0)
                                : thresholdPercent|number_format(2)|trim('0', 'right')|trim('.', 'right'))
                            : null %}
                        {% set usedPct = total > 0 ? (used / total) * 100 : 0 %}
                        {% set backupsPct = total > 0 ? (backupsBytesShown / total) * 100 : 0 %}
                        {% set isLow = threshold is not null and free < threshold %}
                        {% set thresholdPct = (threshold is not null and total > 0) ? ((total - threshold) / total) * 100 : null %}

                        <div class="cb-disk{% if isLow %} cb-disk--low{% endif %}">
                            <div class="cb-disk__bar" role="img"
                                aria-label="{{ 'Disk usage: {used} used of {total}, {free} free'|t('backup', {
                                    used: formatBytes(used),
                                    total: formatBytes(total),
                                    free: formatBytes(free),
                                }) }}">
                                <div class="cb-disk__used" style="width: {{ usedPct|number_format(2, '.', '') }}%;"></div>
                                {% if backupsPct > 0 %}
                                    <div class="cb-disk__backups" style="width: {{ backupsPct|number_format(2, '.', '') }}%;"
                                        title="{{ 'Backups: {size}'|t('backup', { size: formatBytes(backupsBytes) }) }}"></div>
                                {% endif %}
                                {% if thresholdPct is not null %}
                                    <div class="cb-disk__threshold" style="left: {{ thresholdPct|number_format(2, '.', '') }}%;"
                                        title="{% if percentLabel is not null %}{{ 'Warning threshold: {threshold} free ({percent}%)'|t('backup', { threshold: formatBytes(threshold), percent: percentLabel }) }}{% else %}{{ 'Warning threshold: {threshold} free'|t('backup', { threshold: formatBytes(threshold) }) }}{% endif %}"></div>
                                {% endif %}
                            </div>
                            <div class="cb-disk__legend">
                                {% if backupsBytes > 0 %}
                                    <span class="cb-disk__legend-item cb-disk__legend-item--backups">
                                        <span class="cb-disk__swatch cb-disk__swatch--backups" aria-hidden="true"></span>
                                        <strong>{{ formatBytes(backupsBytes) }}</strong>
                                        {{ 'backups'|t('backup') }}
                                    </span>
                                {% endif %}
                                <span class="cb-disk__legend-item">
                                    <strong>{{ formatBytes(used) }}</strong>
                                    {{ 'used'|t('backup') }}
                                </span>
                                <span class="cb-disk__legend-item">
                                    <strong>{{ formatBytes(free) }}</strong>
                                    {{ 'free'|t('backup') }}
                                </span>
                                <span class="cb-disk__legend-item cb-disk__legend-item--total">
                                    {{ 'of {total}'|t('backup', { total: formatBytes(total) }) }}
                                </span>
                                {% if threshold is not null %}
                                    <span class="cb-disk__legend-item cb-disk__legend-item--threshold">
                                        {% if percentLabel is not null %}
                                            {{ 'warn below {threshold} free ({percent}%)'|t('backup', { threshold: formatBytes(threshold), percent: percentLabel }) }}
                                        {% else %}
                                            {{ 'warn below {threshold} free'|t('backup', { threshold: formatBytes(threshold) }) }}
                                        {% endif %}
                                    </span>
                                {% endif %}
                            </div>
                            {% if isLow %}
                                <p class="cb-disk__warning">
                                    {{ 'Free disk space is below the configured warning threshold.'|t('backup') }}
                                </p>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
